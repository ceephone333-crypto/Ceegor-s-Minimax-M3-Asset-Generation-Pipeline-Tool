{
  "name": "ceegor-minimax-m3-asset-generation-pipeline-tool",
  "version": "1.1.27",
  "description": "Cross-modal asset generation GUI for the MiniMax Token Plan — image, speech, music, and video, with a local image pipeline (upscale / crop / format conversion / background removal).",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "status": "node scripts/status.js",
    "setup": "node scripts/setup.js",
    "check": "node scripts/check.js",
    "lint": "node scripts/lint.js",
    "test": "node --test",
    "test:smoke": "node scripts/run-smoke.js",
    "prebuild": "node scripts/check.js",
    "build": "node scripts/zip-portable.js",
    "build:asar": "node scripts/update-zip.js",
    "build:dev": "node scripts/build-dev-zip.js",
    "build:full": "electron-builder --win dir --x64",
    "enable-devmode": "node scripts/enable-devmode.js"
  },
  "keywords": [
    "minimax",
    "mmx",
    "asset-generation",
    "electron",
    "image-pipeline",
    "upscale",
    "crop",
    "format-conversion",
    "background-removal",
    "isnet"
  ],
  "author": "Ceegor",
  "license": "MIT",
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "onnxruntime-node": "^1.18.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "build": {
    "appId": "com.ceegor.minimax-asset-tool",
    "productName": "MiniMaxAssetTool",
    "directories": {
      "output": "dist-out"
    },
    "files": [
      "main.js",
      "main/**/*",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "voices.json"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/*.dll",
      "node_modules/@img/**",
      "node_modules/ffmpeg-static/ffmpeg.exe"
    ],
    "extraResources": [
      { "from": "bin", "to": "bin", "filter": ["**/*", "!input*.jpg", "!*_demo.mp4"] }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MiniMaxAssetTool-${version}-${arch}.${ext}"
    }
  }
}
