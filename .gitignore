# ---- dependencies ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- runtime assets (downloaded by `npm run setup`) ----
# `bin/` is the runtime-asset directory the wrappers look up at
# startup (IS-Net model, Real-ESRGAN binary, VC++ runtime). The
# contents are large (~200 MB) and platform-specific, so we
# populate them locally via `npm run setup` and never commit
# them. The .zip shipped to end users is built FROM this dir
# (see scripts/zip-portable.js), so the build picks up the
# downloaded assets.
bin/

# ---- runtime state (per-user, never commit) ----
# API key lives in config.txt; reset on install.
config.txt
# Per-user generated BatchGen batch lists.
batches.json
# Per-user autosaved tab state (last-opened folder, current tab, etc).
state.json
# Anything the user has generated.
generated/
output/

# ---- build artifacts ----
dist/
dist-build/
dist-out/
# dist-stable/ is the canonical "fresh version" folder. Re-create it
# at any time by extracting dist/MiniMaxAssetTool-1.1.1-x64.zip into
# dist-stable/. The launch exe is then at
#   dist-stable/win-unpacked/MiniMaxAssetTool.exe
# Future agents MUST keep this folder up-to-date after every change:
# re-sync dist-stable/win-unpacked/resources/app.asar from the source
# via scripts/sync-stable-asar.js (see HANDOFF.md). The .bak file is
# the previous asar (kept so a failed repack can be reverted).
dist-stable/
dist-stable/asar-work/
# dist-final/ is the asar-distribution folder produced by the
# `npm run build:dir` + manual `sync-asar` flow that lives
# alongside dist/. It is regenerated by re-running the same
# steps (see scripts/sync-asar.ps1 + the sync-asar PowerShell
# one-liner in .trae/memory), so it doesn't need to be
# tracked. The portable .zip that ships to end users is
# built FROM this folder.
dist-final/
out/
build/
# ReleaseGithub/ is the staged-source release folder we build before
# zipping it for a GitHub release. It's regenerated by re-running the
# copy commands (see commit log), so it doesn't need to be tracked.
ReleaseGithub/
*.exe
*.dmg
*.AppImage
*.snap
*.deb
*.rpm
*.zip
*.tar.gz

# ---- test / debug output ----
test-*.js
test-*.log
*.log
debug.log

# ---- IDE / editor ----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- node / electron ----
*.log
.npm/
.eslintcache
node_modules/
# package-lock.json is committed for reproducible builds.
yarn.lock
pnpm-lock.yaml

# ---- environment / secrets ----
.env
.env.local
.env.*.local
*.pem
*.key
dist-verify/
